<% flash.each do |message_type, message| %>
  <div class="alert alert-<%= message_type %>">
    <%= message %>
  </div>
<% end %>

<div>
  <div>
    <div>
      <h1><%= t('.title') %></h1>
      <%= form_with url: login_path, scope: :session, local: true, data: { turbo: false } do |f| %>
        <div>
          <%= f.label :email, t('.email') %>
          <%= f.email_field :email, name: 'session[email]' %>
        </div>
        <div>
          <%= f.label :password, t('.password') %>
          <%= f.password_field :password, name: 'session[password]' %>
        </div>
        <%= f.submit t('.login') %>
      <% end %>
      <div>
        <%= link_to t('.to_register_page'), new_user_path %>
        <%= link_to t('.password_forget'), '#' %>
      </div>
    </div>
  </div>
</div>