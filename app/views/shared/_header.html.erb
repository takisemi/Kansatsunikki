<header>
  <div class="w-full max-w-3/4 flex">
  <div class="flex justify-start">
    <%= link_to '/', class: 'toppage' do %>
      <%= image_tag 'logo.png' %>
    <% end %>

    <div class="flex justify-end">
      <div>
        <ul>
          <li><%= current_user.last_name %> <%= current_user.first_name %></li>
        </ul>
        <%= link_to t('header.posts'), posts_path %>
        <%= button_to t('header.logout'), logout_path, method: :delete, data: { turbo_method: :delete } %>

        <%# @user を使わず、current_user で判定 %>
        <% if logged_in? && current_user.email != "test@example.com" %>
          <%= link_to t('header.user_destroy'), 
            user_path(current_user), 
            data: { 
              turbo_method: :delete, 
              turbo_confirm: t('header.user_destroy_confirmation') 
            } %>
          <% end %>
      </div>
    </div>
  </div>
  </div>
</header>